---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import '../styles/adm-in-brand.css';

const serializedSite = JSON.stringify(site).replace(/</g, '\\u003c');
const publicSupabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const publicSupabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
const publicSiteContentKey = import.meta.env.PUBLIC_SITE_CONTENT_KEY || 'main';
const serializedConfig = JSON.stringify({
  supabaseUrl: publicSupabaseUrl,
  supabaseAnonKey: publicSupabaseAnonKey,
  contentKey: publicSiteContentKey,
}).replace(/</g, '\\u003c');
---

<BaseLayout title="Adm-in-brand" description="Panel privado para editar contenido en vivo.">
  <main class="adm-shell">
    <section class="adm-card" id="authCard">
      <h1>Adm-in-brand</h1>
      <p>Acceso privado al editor visual.</p>
      <form id="loginForm" class="adm-form">
        <label for="adminEmail">Email</label>
        <input id="adminEmail" type="email" placeholder="admin@tu-dominio.com" required />

        <label for="adminPassword">Password</label>
        <input id="adminPassword" type="password" placeholder="Tu clave" required />

        <button type="submit">Entrar</button>
      </form>
      <p id="authMessage" class="adm-message" aria-live="polite"></p>
    </section>

    <section class="adm-workspace" id="workspace" hidden>
      <aside class="adm-sidebar">
        <div class="adm-sidebar-head">
          <h2>Editor visual</h2>
          <button id="logoutBtn" type="button" class="ghost">Salir</button>
        </div>

        <p class="helper">Pasa el mouse o haz click en un texto/imagen del preview para editarlo.</p>

        <div class="field-meta">
          <p><strong>Ruta:</strong> <span id="fieldPath">-</span></p>
          <p><strong>Tipo:</strong> <span id="fieldType">-</span></p>
        </div>

        <label for="fieldValue">Nuevo valor</label>
        <textarea id="fieldValue" rows="8" placeholder="Selecciona un elemento para editar"></textarea>

        <div class="actions">
          <button id="saveBtn" type="button">Guardar online</button>
          <div class="history-actions">
            <button id="undoBtn" type="button" class="ghost" disabled>Deshacer</button>
            <button id="redoBtn" type="button" class="ghost" disabled>Rehacer</button>
          </div>
        </div>

        <div class="history-panel">
          <p class="history-title">Historial reciente</p>
          <ul id="historyList"></ul>
        </div>

        <p id="saveMessage" class="adm-message" aria-live="polite"></p>
      </aside>

      <div class="adm-preview-wrap">
        <iframe id="previewFrame" src="/?adm-preview=1" title="Vista previa del sitio"></iframe>
      </div>
    </section>
  </main>

  <script id="adm-fallback" type="application/json" set:html={serializedSite}></script>
  <script id="adm-config" type="application/json" set:html={serializedConfig}></script>

  <script>
    const fallbackEl = document.getElementById('adm-fallback');
    const configEl = document.getElementById('adm-config');
    const fallbackContent = fallbackEl ? JSON.parse(fallbackEl.textContent || '{}') : {};
    const config = configEl ? JSON.parse(configEl.textContent || '{}') : {};

    const loginForm = document.getElementById('loginForm');
    const authMessage = document.getElementById('authMessage');
    const authCard = document.getElementById('authCard');
    const workspace = document.getElementById('workspace');
    const fieldPathEl = document.getElementById('fieldPath');
    const fieldTypeEl = document.getElementById('fieldType');
    const fieldValueEl = document.getElementById('fieldValue');
    const saveMessage = document.getElementById('saveMessage');
    const saveBtn = document.getElementById('saveBtn');
    const undoBtn = document.getElementById('undoBtn');
    const redoBtn = document.getElementById('redoBtn');
    const historyList = document.getElementById('historyList');
    const logoutBtn = document.getElementById('logoutBtn');
    const previewFrame = document.getElementById('previewFrame');
    const loginBtn = loginForm?.querySelector('button[type="submit"]');

    const supabaseUrl = config.supabaseUrl || '';
    const supabaseAnonKey = config.supabaseAnonKey || '';
    const contentKey = config.contentKey || 'main';

    const apiBase = `${supabaseUrl}/rest/v1`;
    const authBase = `${supabaseUrl}/auth/v1`;
    let accessToken = '';

    if (!supabaseUrl || !supabaseAnonKey) {
      authMessage.textContent = 'Faltan PUBLIC_SUPABASE_URL y PUBLIC_SUPABASE_ANON_KEY en variables de entorno.';
      loginForm?.setAttribute('hidden', 'hidden');
      throw new Error('Missing Supabase env vars');
    }

    let currentContent = structuredClone(fallbackContent);
    let currentTarget = null;
    let currentBinding = null;
    let previewBridgeReady = false;
    const undoStack = [];
    const redoStack = [];
    const maxHistoryEntries = 20;

    const isElementNode = (node) => Boolean(node && node.nodeType === 1);
    const nodeTag = (node) => (isElementNode(node) ? String(node.tagName || '').toUpperCase() : '');

    const setActiveElement = (element) => {
      const mappings = getMappings(element);
      if (!mappings.length) return;

      if (currentTarget && currentTarget !== element) {
        currentTarget.removeAttribute('data-adm-selected');
      }

      currentTarget = element;
      currentTarget.setAttribute('data-adm-selected', 'true');
      currentBinding = mappings[0];
      renderSelection();

      if (fieldValueEl instanceof HTMLTextAreaElement) {
        fieldValueEl.focus();
        fieldValueEl.setSelectionRange(0, fieldValueEl.value.length);
      }
    };

    const getByPath = (source, path) => path.split('.').reduce((acc, segment) => {
      if (acc == null) return undefined;
      return acc[segment];
    }, source);

    const setByPath = (source, path, value) => {
      const segments = path.split('.');
      let cursor = source;

      for (let i = 0; i < segments.length - 1; i += 1) {
        const key = segments[i];
        const next = segments[i + 1];
        if (cursor[key] == null) {
          cursor[key] = /^\d+$/.test(next) ? [] : {};
        }
        cursor = cursor[key];
      }

      cursor[segments[segments.length - 1]] = value;
    };

    const getMappings = (element) => {
      const raw = [
        { attr: 'data-content-path', type: 'text' },
        { attr: 'data-content-src-path', type: 'image-src' },
        { attr: 'data-content-href-path', type: 'link-href' },
        { attr: 'data-content-placeholder-path', type: 'placeholder' },
        { attr: 'data-content-alt-path', type: 'image-alt' },
      ];

      return raw
        .map((item) => {
          const path = element.getAttribute(item.attr);
          if (!path) return null;
          return { ...item, path };
        })
        .filter(Boolean);
    };

    const renderSelection = () => {
      if (!currentBinding) {
        fieldPathEl.textContent = '-';
        fieldTypeEl.textContent = '-';
        fieldValueEl.value = '';
        fieldValueEl.placeholder = 'Selecciona un elemento para editar';
        return;
      }

      fieldPathEl.textContent = currentBinding.path;
      fieldTypeEl.textContent = currentBinding.type;
      const value = getByPath(currentContent, currentBinding.path);
      fieldValueEl.value = value == null ? '' : String(value);
      fieldValueEl.placeholder = 'Escribe el nuevo valor y presiona Guardar online';
    };

    const updatePreviewValue = (element, binding, value) => {
      if (!element || !binding) return;

      const tag = nodeTag(element);

      if (binding.type === 'text') {
        element.textContent = value;
      }

      if (binding.type === 'image-src' && tag === 'IMG') {
        element.src = value;
      }

      if (binding.type === 'image-alt' && tag === 'IMG') {
        element.alt = value;
      }

      if (binding.type === 'link-href' && tag === 'A') {
        element.href = value;
      }

      if (binding.type === 'placeholder' && (tag === 'INPUT' || tag === 'TEXTAREA')) {
        element.placeholder = value;
      }
    };

    const setSaveMessage = (message, isError = false) => {
      saveMessage.textContent = message;
      saveMessage.classList.toggle('error', isError);
    };

    const escapeAttributeValue = (value) => String(value).replace(/\\/g, '\\\\').replace(/"/g, '\\"');

    const updateButtonsState = () => {
      if (undoBtn instanceof HTMLButtonElement) {
        undoBtn.disabled = undoStack.length === 0;
      }
      if (redoBtn instanceof HTMLButtonElement) {
        redoBtn.disabled = redoStack.length === 0;
      }
    };

    const renderHistory = () => {
      if (!(historyList instanceof HTMLUListElement)) return;

      const latest = undoStack.slice(-6).reverse();
      historyList.innerHTML = '';

      if (!latest.length) {
        const emptyItem = document.createElement('li');
        emptyItem.textContent = 'Sin cambios guardados.';
        historyList.appendChild(emptyItem);
        updateButtonsState();
        return;
      }

      latest.forEach((entry) => {
        const item = document.createElement('li');
        item.textContent = `${entry.path} -> ${entry.nextValue}`;
        historyList.appendChild(item);
      });

      updateButtonsState();
    };

    const updatePreviewByPath = (bindingType, path, value) => {
      const frameDoc = previewFrame?.contentDocument;
      if (!frameDoc) return;

      const bindingAttrByType = {
        text: 'data-content-path',
        'image-src': 'data-content-src-path',
        'link-href': 'data-content-href-path',
        placeholder: 'data-content-placeholder-path',
        'image-alt': 'data-content-alt-path',
      };

      const attr = bindingAttrByType[bindingType];
      if (!attr) return;

      const selector = `[${attr}="${escapeAttributeValue(path)}"]`;
      frameDoc.querySelectorAll(selector).forEach((element) => {
        updatePreviewValue(element, { type: bindingType, path }, String(value ?? ''));
      });
    };

    const persistContent = async () => {
      if (!accessToken) {
        setSaveMessage('Sesion expirada. Vuelve a iniciar sesion.', true);
        return false;
      }

      const response = await fetch(`${apiBase}/site_content?on_conflict=key`, {
        method: 'POST',
        headers: {
          apikey: supabaseAnonKey,
          Authorization: `Bearer ${accessToken}`,
          'Content-Type': 'application/json',
          Prefer: 'resolution=merge-duplicates,return=representation',
        },
        body: JSON.stringify([
          {
            key: contentKey,
            content: currentContent,
            updated_at: new Date().toISOString(),
          },
        ]),
      });

      if (!response.ok) {
        const errorPayload = await response.json().catch(() => ({}));
        setSaveMessage(`Error guardando: ${errorPayload.message || `HTTP ${response.status}`}`, true);
        return false;
      }

      return true;
    };

    const loadContent = async () => {
      try {
        const response = await fetch(
          `${apiBase}/site_content?key=eq.${encodeURIComponent(contentKey)}&select=content&limit=1`,
          {
            headers: {
              apikey: supabaseAnonKey,
              Authorization: accessToken ? `Bearer ${accessToken}` : `Bearer ${supabaseAnonKey}`,
            },
          },
        );

        if (!response.ok) {
          const errorPayload = await response.json().catch(() => ({}));
          throw new Error(errorPayload.message || `HTTP ${response.status}`);
        }

        const rows = await response.json();
        const row = Array.isArray(rows) ? rows[0] : null;

        if (row?.content && typeof row.content === 'object') {
          currentContent = row.content;
        } else {
          currentContent = structuredClone(fallbackContent);
        }

        renderSelection();
        setSaveMessage('Contenido cargado desde Supabase.');
      } catch (error) {
        const message = error instanceof Error ? error.message : 'No se pudo cargar contenido.';
        currentContent = structuredClone(fallbackContent);
        renderSelection();

        if (String(message).includes("Could not find the table 'public.site_content'")) {
          setSaveMessage('Falta crear la tabla site_content en Supabase (SQL Editor). Ejecuta el script de setup y recarga.', true);
          return;
        }

        setSaveMessage(`No se pudo leer site_content en Supabase: ${message}`, true);
      }
    };

    const saveContent = async () => {
      if (!currentBinding || !currentTarget) {
        setSaveMessage('Selecciona primero un elemento del preview.', true);
        return;
      }

      const nextValue = fieldValueEl.value;
      const previousValueRaw = getByPath(currentContent, currentBinding.path);
      const previousValue = previousValueRaw == null ? '' : String(previousValueRaw);

      if (previousValue === nextValue) {
        setSaveMessage('No hay cambios para guardar.');
        return;
      }

      setByPath(currentContent, currentBinding.path, nextValue);
      updatePreviewValue(currentTarget, currentBinding, nextValue);

      const persisted = await persistContent();
      if (!persisted) {
        setByPath(currentContent, currentBinding.path, previousValue);
        updatePreviewValue(currentTarget, currentBinding, previousValue);
        return;
      }

      undoStack.push({
        path: currentBinding.path,
        type: currentBinding.type,
        previousValue,
        nextValue,
      });

      if (undoStack.length > maxHistoryEntries) {
        undoStack.shift();
      }

      redoStack.length = 0;
      renderHistory();

      setSaveMessage('Guardado online correctamente.');
    };

    const applyHistoryEntry = async (entry, direction) => {
      const toValue = direction === 'undo' ? entry.previousValue : entry.nextValue;
      const rollbackValue = direction === 'undo' ? entry.nextValue : entry.previousValue;

      setByPath(currentContent, entry.path, toValue);
      updatePreviewByPath(entry.type, entry.path, toValue);

      const persisted = await persistContent();
      if (!persisted) {
        setByPath(currentContent, entry.path, rollbackValue);
        updatePreviewByPath(entry.type, entry.path, rollbackValue);
        return;
      }

      if (currentBinding && currentBinding.path === entry.path && currentBinding.type === entry.type) {
        renderSelection();
      }

      if (direction === 'undo') {
        redoStack.push(entry);
        setSaveMessage('Cambio revertido correctamente.');
      } else {
        undoStack.push(entry);
        setSaveMessage('Cambio rehecho correctamente.');
      }

      renderHistory();
    };

    const setupPreviewBridge = () => {
      const frameDoc = previewFrame?.contentDocument;
      if (!frameDoc) return;

      if (frameDoc.getElementById('adm-bridge-style')) {
        previewBridgeReady = true;
        return;
      }

      const style = frameDoc.createElement('style');
      style.id = 'adm-bridge-style';
      style.textContent = `
        [data-content-path],
        [data-content-src-path],
        [data-content-href-path],
        [data-content-placeholder-path],
        [data-content-alt-path] {
          outline: 2px dashed rgba(200, 145, 58, 0.25);
          outline-offset: 2px;
          cursor: pointer;
        }

        [data-adm-selected="true"] {
          outline: 2px solid #1B4E81 !important;
          box-shadow: 0 0 0 4px rgba(27, 78, 129, 0.14);
        }
      `;
      frameDoc.head.appendChild(style);

      const pickEditable = (target) => {
        const origin = isElementNode(target)
          ? target
          : target && isElementNode(target.parentElement)
            ? target.parentElement
            : null;

        if (!origin) return null;

        return origin.closest('[data-content-path], [data-content-src-path], [data-content-href-path], [data-content-placeholder-path], [data-content-alt-path]');
      };

      frameDoc.addEventListener('pointerdown', (event) => {
        const element = pickEditable(event.target);
        if (!element) return;

        event.preventDefault();
        event.stopPropagation();
        setActiveElement(element);
      }, true);

      frameDoc.addEventListener('mouseover', (event) => {
        const element = pickEditable(event.target);
        if (!element) return;
        setActiveElement(element);
      }, true);

      frameDoc.addEventListener('click', (event) => {
        const element = pickEditable(event.target);
        if (!element) return;

        event.preventDefault();
        event.stopPropagation();

        setActiveElement(element);
      }, true);

      previewBridgeReady = true;
    };

    const initPreviewBridge = () => {
      if (previewBridgeReady) return;
      const frameDoc = previewFrame?.contentDocument;
      if (!frameDoc || frameDoc.readyState === 'loading') return;
      setupPreviewBridge();
    };

    const openWorkspace = async () => {
      authCard.hidden = true;
      workspace.hidden = false;
      await loadContent();
      initPreviewBridge();
    };

    loginForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = document.getElementById('adminEmail')?.value || '';
      const password = document.getElementById('adminPassword')?.value || '';

      if (loginBtn instanceof HTMLButtonElement) {
        loginBtn.disabled = true;
        loginBtn.textContent = 'Entrando...';
      }

      authMessage.textContent = 'Validando acceso...';
      try {
        const response = await fetch(`${authBase}/token?grant_type=password`, {
          method: 'POST',
          headers: {
            apikey: supabaseAnonKey,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email, password }),
        });

        const payload = await response.json().catch(() => ({}));

        if (!response.ok || !payload.access_token) {
          authMessage.textContent = `Acceso denegado: ${payload.error_description || payload.msg || payload.message || 'Credenciales invalidas'}`;
          return;
        }

        accessToken = payload.access_token;

        authMessage.textContent = '';
        await openWorkspace();
      } catch (error) {
        const message = error instanceof Error ? error.message : 'No se pudo iniciar sesion.';
        authMessage.textContent = `Error de conexion con Supabase: ${message}`;
      } finally {
        if (loginBtn instanceof HTMLButtonElement) {
          loginBtn.disabled = false;
          loginBtn.textContent = 'Entrar';
        }
      }
    });

    saveBtn?.addEventListener('click', () => {
      saveContent().catch((error) => {
        setSaveMessage(`Error guardando: ${error.message}`, true);
      });
    });

    undoBtn?.addEventListener('click', () => {
      const entry = undoStack.pop();
      if (!entry) {
        renderHistory();
        return;
      }

      applyHistoryEntry(entry, 'undo').catch((error) => {
        undoStack.push(entry);
        renderHistory();
        setSaveMessage(`Error al deshacer: ${error.message}`, true);
      });
    });

    redoBtn?.addEventListener('click', () => {
      const entry = redoStack.pop();
      if (!entry) {
        renderHistory();
        return;
      }

      applyHistoryEntry(entry, 'redo').catch((error) => {
        redoStack.push(entry);
        renderHistory();
        setSaveMessage(`Error al rehacer: ${error.message}`, true);
      });
    });

    fieldValueEl?.addEventListener('input', () => {
      if (!currentBinding || !currentTarget) return;
      updatePreviewValue(currentTarget, currentBinding, fieldValueEl.value);
    });

    logoutBtn?.addEventListener('click', async () => {
      accessToken = '';
      workspace.hidden = true;
      authCard.hidden = false;
      authMessage.textContent = 'Sesion cerrada.';
      setSaveMessage('');
    });

    previewFrame?.addEventListener('load', () => {
      initPreviewBridge();
    });

    renderHistory();

  </script>
</BaseLayout>
