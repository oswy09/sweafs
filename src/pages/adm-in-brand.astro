---
import '../styles/adm-in-brand.css';
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const CONTENT_KEY  = import.meta.env.PUBLIC_SITE_CONTENT_KEY ?? 'main';
const BUILD_HOOK   = import.meta.env.NETLIFY_BUILD_HOOK_URL ?? '';
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin · Swea Fastighetsservice</title>
  <meta name="robots" content="noindex,nofollow"/>
</head>
<body>

<!-- ══ LOGIN ══ -->
<div class="adm-login-wrap" id="loginScreen">
  <div class="adm-login-card">
    <div class="adm-login-logo">
      <div class="adm-logo-mark">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#c8913a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </div>
      <div class="adm-login-name">Swea <span>Admin</span></div>
      <div class="adm-login-sub">Dashboard</div>
    </div>
    <h1>Sign in</h1>
    <div class="adm-form">
      <div>
        <label for="loginEmail">Email address</label>
        <input class="adm-input" type="email" id="loginEmail" placeholder="admin@example.com" autocomplete="email"/>
      </div>
      <div>
        <label for="loginPass">Password</label>
        <input class="adm-input" type="password" id="loginPass" placeholder="••••••••" autocomplete="current-password"/>
      </div>
      <button class="btn-primary" id="loginBtn">Sign in</button>
      <p class="adm-msg" id="loginMsg"></p>
    </div>
  </div>
</div>

<!-- ══ APP ══ -->
<div class="adm-app" id="admApp" hidden>

  <!-- TOPBAR -->
  <header class="adm-topbar">
    <div class="adm-topbar-left">
      <button class="adm-toggle-btn" id="sidebarToggle" title="Collapse/expand menu">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      <div class="adm-brand-label">
        <div class="adm-brand-name">Swea <span>Admin</span></div>
        <div class="adm-brand-sub">FASTIGHETSSERVICE</div>
      </div>
    </div>
    <div class="adm-topbar-right">
      <span class="adm-status-badge" id="statusBadge">Connected</span>
      <button class="btn-topbar pub" id="publishBtn">↑ Publicar sitio</button>
      <div class="adm-avatar" id="userAvatar" title=""></div>
      <button class="btn-topbar" id="logoutBtn">Sign out</button>
    </div>
  </header>

  <!-- SIDEBAR -->
  <nav class="adm-sidebar">

    <div class="adm-nav-group">
      <div class="adm-nav-item active" data-panel="dashboard">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        <span class="adm-nav-text">Dashboard</span>
      </div>
    </div>

    <div class="adm-nav-group">
      <span class="adm-nav-section-label">Pages</span>
      <div class="adm-nav-item" data-panel="pages">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <span class="adm-nav-text">All pages</span>
      </div>
      <div class="adm-sb-pages" id="sbPages">
        <div class="adm-sb-page" data-url="/" data-label="Home">
          <span class="adm-sb-page-dot"></span>Home
        </div>
        <div class="adm-sb-page" data-url="/style-guide" data-label="Style Guide">
          <span class="adm-sb-page-dot"></span>Style Guide
        </div>
      </div>
    </div>

    <div class="adm-nav-group">
      <span class="adm-nav-section-label">Content</span>
      <div class="adm-nav-item" data-panel="sections">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        <span class="adm-nav-text">Sections</span>
      </div>
      <div class="adm-nav-item" data-panel="seo">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="adm-nav-text">SEO</span>
      </div>
    </div>

    <div class="adm-nav-group">
      <span class="adm-nav-section-label">System</span>
      <div class="adm-nav-item" data-panel="settings">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        <span class="adm-nav-text">Settings</span>
      </div>
      <div class="adm-nav-item" data-panel="users">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span class="adm-nav-text">Users</span>
      </div>
    </div>

  </nav>

  <!-- ══ CONTENT AREA ══ -->
  <div class="adm-content" id="admContent">

    <!-- ── DASHBOARD ── -->
    <div class="adm-panel panel-active" id="dashboardPanel">
      <div class="dash-wrap">

        <div class="dash-header">
          <div class="dash-logo">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#c8913a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div>
            <div class="dash-site-name">Swea <span>Fastighetsservice</span></div>
            <div class="dash-site-meta">
              <span>sweafs.se</span>
              <span>·</span>
              <span id="dashLastUpdate">Loading...</span>
            </div>
          </div>
        </div>

        <div class="dash-stats">
          <div class="dash-stat c-accent">
            <div class="dash-stat-label">Site type</div>
            <div class="dash-stat-val" style="font-size:.95rem;margin-top:.15rem">Static</div>
            <div class="dash-stat-sub">One Page / SSG</div>
          </div>
          <div class="dash-stat c-blue">
            <div class="dash-stat-label">Framework</div>
            <div class="dash-stat-val" style="font-size:.95rem;margin-top:.15rem">Astro 5</div>
            <div class="dash-stat-sub">Build time rendering</div>
          </div>
          <div class="dash-stat c-green">
            <div class="dash-stat-label">Database</div>
            <div class="dash-stat-val" style="font-size:.95rem;margin-top:.15rem">Supabase</div>
            <div class="dash-stat-sub">PostgreSQL + Auth</div>
          </div>
          <div class="dash-stat c-muted">
            <div class="dash-stat-label">Hosting</div>
            <div class="dash-stat-val" style="font-size:.95rem;margin-top:.15rem">Netlify</div>
            <div class="dash-stat-sub">Global CDN + CI/CD</div>
          </div>
        </div>

        <div class="dash-2col">

          <div class="dash-card">
            <div class="dash-card-head">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              <h3>Tech stack</h3>
            </div>
            <div class="dash-card-body">
              <div class="tech-pills">
                <span class="tech-pill astro">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M16.074 16.86C15.354 17.476 13.91 17.9 12.24 17.9c-2.07 0-3.788-.681-4.249-1.604-.163.496-.2 1.005-.2 1.37 0 0-.107 1.756 1.12 2.983.64.64 1.486.976 2.374.967a3.68 3.68 0 0 0 3.026-1.569c.574-.832.763-1.895.763-3.187Z"/><path d="M16.074 16.86c.355-.299.745-.67.802-1.04.077-.497-.2-1.008-.62-1.278-.383-.248-.877-.24-1.25-.029-.454.258-.618.76-.69 1.234-.07.47-.046.938.058 1.4.18-.145.433-.168.7-.288Z"/><path d="M7.775 9.568 10.9 1.128a.315.315 0 0 1 .595 0l3.124 8.44a.315.315 0 0 0 .293.205h3.417c.244 0 .371.29.209.474l-5.773 6.557a.315.315 0 0 1-.533-.12l-1.6-5.043a.315.315 0 0 0-.3-.22H7.874a.315.315 0 0 1-.236-.528l.137-.325Z"/></svg>
                  Astro 5
                </span>
                <span class="tech-pill vue">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M2 3h3.5L12 15l6.5-12H22L12 21 2 3zm4.5 0h3L12 9.5 14.5 3h3L12 15 6.5 3z"/></svg>
                  Vue 3
                </span>
                <span class="tech-pill supabase">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M11.9 1.036c-.015-.986-1.26-1.41-1.874-.637L.764 13.017c-.542.696-.042 1.716.825 1.716h7.861l.34 8.237c.015.986 1.26 1.41 1.874.637l9.262-12.618c.542-.696.042-1.716-.825-1.716h-7.861L11.9 1.036z"/></svg>
                  Supabase
                </span>
                <span class="tech-pill netlify">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M16.934 8.519a1.044 1.044 0 0 1 .303.23l2.349-1.045-2.192-2.171-.491 2.954zM12.06 6.546a1.305 1.305 0 0 1 .209.574l3.497 1.258 .488-2.926-2.953-.938-1.24 2.032zm-2.1 3.sofá-.586 1.05 1.75-1.32-.35-1.86-1.15 1.186zm4.44-1.657l-3.522-1.265-.386.692 2.8 3.337 1.108-2.764zm-3.4 3.76l-1.76 1.327 1.74 2.063.9.093.584-1.037L10.46 12zm-3.32.556-.93.7.25 1.52 1.35-1.344-.67-.876zm-3.1 2.338l.61.37 1.13-1.126-.94-1.22-.8.6v1.376zm-.5-2.78l-.616-.37-.456 2.738.617.373.455-2.74zm12.04 2.27l.79-1.403-2.81-3.345-1.1 2.747 3.12 2zm-8.7 4.55l.73.445 4.32-5.128-.9-.093-4.15 4.776zm-2.1-1.283L4.76 19l.16.097 2.91-2.9-.68-.884zm-.5-.3l-.61-.37-.17 1.026.1.06.68-.716zm11.44-2.36l1.9 1.154.13-.204-1.66-1.64-.37.69zm.87 2.02l-1.9-1.155-.19.34 1.57 1.554.52-.739zm2.27 1.378l.08-.12-1.76-1.74-.52.74 2.2 1.12zm1.02-1.6L19.1 19.8l.44-.655-1.35-1.337-.35.654z"/></svg>
                  Netlify
                </span>
                <span class="tech-pill ts">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M1.125 0C.502 0 0 .502 0 1.125v21.75C0 23.498.502 24 1.125 24h21.75c.623 0 1.125-.502 1.125-1.125V1.125C24 .502 23.498 0 22.875 0zm17.363 9.75c.612 0 1.154.037 1.627.111a6.38 6.38 0 0 1 1.306.34v2.458a3.95 3.95 0 0 0-.643-.361 5.093 5.093 0 0 0-.717-.26 5.453 5.453 0 0 0-1.426-.2c-.3 0-.573.028-.819.086a2.1 2.1 0 0 0-.623.242c-.17.104-.3.229-.393.374a.888.888 0 0 0-.14.49c0 .196.053.373.156.529.104.156.252.304.443.444s.423.276.696.41c.273.135.582.274.926.416.47.197.892.407 1.266.628.374.222.695.473.963.753.268.279.472.598.614.957.142.359.214.776.214 1.253 0 .657-.125 1.21-.373 1.656a3.033 3.033 0 0 1-1.012 1.085 4.38 4.38 0 0 1-1.487.596c-.566.12-1.163.18-1.79.18a9.916 9.916 0 0 1-1.84-.164 5.544 5.544 0 0 1-1.512-.493v-2.63a5.033 5.033 0 0 0 3.237 1.2c.333 0 .624-.03.872-.09.249-.06.456-.144.623-.25.166-.108.29-.234.373-.38a1.023 1.023 0 0 0-.074-1.089 2.12 2.12 0 0 0-.537-.5 5.597 5.597 0 0 0-.807-.444 27.72 27.72 0 0 0-1.007-.436c-.918-.383-1.602-.852-2.053-1.405-.45-.553-.676-1.222-.676-2.005 0-.614.123-1.141.369-1.582.246-.441.58-.804 1.004-1.089a4.494 4.494 0 0 1 1.47-.629 7.536 7.536 0 0 1 1.77-.201zm-15.113.188h9.563v2.166H9.506v9.646H6.789v-9.646H3.375z"/></svg>
                  TypeScript
                </span>
                <span class="tech-pill tailwind">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12.001 4.8c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624C13.666 10.618 15.027 12 18.001 12c3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-.913-.228-1.565-.89-2.288-1.624C16.337 6.182 14.976 4.8 12.001 4.8zm-6 7.2c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624 1.177 1.194 2.538 2.576 5.512 2.576 3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-.913-.228-1.565-.89-2.288-1.624C10.337 13.382 8.976 12 6.001 12z"/></svg>
                  Tailwind
                </span>
              </div>
            </div>
          </div>

          <div class="dash-card">
            <div class="dash-card-head">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              <h3>Performance &amp; optimization</h3>
            </div>
            <div class="dash-card-body">
              <div class="perf-row"><span class="perf-label">Lighthouse Performance</span><span class="perf-badge g">~98</span></div>
              <div class="perf-row"><span class="perf-label">SEO Score</span><span class="perf-badge g">~100</span></div>
              <div class="perf-row"><span class="perf-label">Accessibility</span><span class="perf-badge g">~95</span></div>
              <div class="perf-row"><span class="perf-label">Best Practices</span><span class="perf-badge g">~100</span></div>
              <div class="perf-row"><span class="perf-label">Generation</span><span class="perf-badge b">Static (SSG)</span></div>
              <div class="perf-row"><span class="perf-label">Deploy</span><span class="perf-badge b">Netlify CDN</span></div>
            </div>
          </div>

        </div>

        <div class="dash-card" style="margin-bottom:1.2rem">
          <div class="dash-card-head">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <h3>Quick actions</h3>
          </div>
          <div class="dash-card-body">
            <div class="qa-grid">
              <button class="qa-btn" onclick="switchPanel('pages')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                <span>Edit page</span>
              </button>
              <button class="qa-btn" onclick="switchPanel('seo')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <span>Configure SEO</span>
              </button>
              <button class="qa-btn" onclick="switchPanel('sections')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                <span>Sort sections</span>
              </button>
              <button class="qa-btn" onclick="switchPanel('settings')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                <span>Settings</span>
              </button>
              <button class="qa-btn" id="qaPublish">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                <span>Publish site</span>
              </button>
            </div>
          </div>
        </div>

      </div>
    </div><!-- /dashboardPanel -->

    <!-- ── PAGES LIST ── -->
    <div class="adm-panel" id="pagesPanel">
      <div class="adm-panel-wrap">
        <div class="adm-panel-inner">
          <div class="adm-panel-title">Pages</div>
          <div class="adm-panel-sub">Select a page to edit it in the preview.</div>
          <div class="adm-section-card">
            <div class="adm-section-card-body" style="padding:.6rem">
              <div style="display:grid;gap:.3rem">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:.6rem .75rem;background:#f6f7f7;border:1px solid var(--border);border-radius:4px;cursor:pointer" onclick="openPreview('/', 'Inicio')">
                  <div style="display:flex;align-items:center;gap:.6rem">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                    <span style="font-size:.82rem;font-weight:600">Home</span>
                    <span style="font-size:.72rem;color:var(--muted)">/</span>
                  </div>
                  <span style="font-size:.72rem;color:var(--blue)">Edit →</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:.6rem .75rem;background:#f6f7f7;border:1px solid var(--border);border-radius:4px;cursor:pointer" onclick="openPreview('/style-guide', 'Style Guide')">
                  <div style="display:flex;align-items:center;gap:.6rem">
