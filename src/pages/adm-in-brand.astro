<script define:vars={{ SUPABASE_URL, SUPABASE_KEY, CONTENT_KEY, BUILD_HOOK }}>
const SB_URL = (SUPABASE_URL ?? '').trim().replace(/[^\x20-\x7E]/g, '');
const SB_KEY = (SUPABASE_KEY ?? '').trim().replace(/[^\x20-\x7E]/g, '');
const CKEY   = CONTENT_KEY ?? 'main';
const HOOK   = BUILD_HOOK ?? '';

let accessToken = null;
let site = {};
let hist = [], histIdx = -1;

function getInitials(email) {
  const name = email.split('@')[0];
  const parts = name.split(/[._-]/);
  return parts.length >= 2
    ? (parts[0][0] + parts[1][0]).toUpperCase()
    : name.slice(0,2).toUpperCase();
}
function setAvatar(email) {
  const av = document.getElementById('userAvatar');
  av.textContent = getInitials(email);
  av.title = email;
}

const sbH = () => ({
  apikey: SB_KEY,
  Authorization: `Bearer ${accessToken || SB_KEY}`,
  'Content-Type': 'application/json',
});

async function sbLogin(email, pw) {
  const r = await fetch(`${SB_URL}/auth/v1/token?grant_type=password`, {
    method: 'POST',
    headers: { apikey: SB_KEY, 'Content-Type': 'application/json' },
    body: JSON.stringify({ email, password: pw }),
  });
  return r.json();
}

async function loadContent() {
  const r = await fetch(`${SB_URL}/rest/v1/site_content?key=eq.${encodeURIComponent(CKEY)}&select=content,updated_at&limit=1`, { headers: sbH() });
  if (!r.ok) throw new Error(`HTTP ${r.status}`);
  const rows = await r.json();
  if (rows.length) {
    const d = new Date(rows[0].updated_at);
    document.getElementById('dashLastUpdate').textContent = `Last edited: ${d.toLocaleDateString('en', { day:'2-digit', month:'short', year:'numeric' })}`;
    return rows[0].content ?? {};
  }
  document.getElementById('dashLastUpdate').textContent = 'Sin contenido guardado';
  return {};
}

async function saveContent(data) {
  const r = await fetch(`${SB_URL}/rest/v1/site_content?key=eq.${encodeURIComponent(CKEY)}`, {
    method: 'PATCH',
    headers: { ...sbH(), Prefer: 'return=minimal' },
    body: JSON.stringify({ content: data, updated_at: new Date().toISOString() }),
  });
  if (!r.ok) throw new Error(`HTTP ${r.status}`);
}

/* ── LOGIN ── */
const loginScreen = document.getElementById('loginScreen');
const admApp = document.getElementById('admApp');
const loginBtn = document.getElementById('loginBtn');
const loginMsg = document.getElementById('loginMsg');

/* ── AUTO-LOGIN from localStorage ── */
(function() {
  const saved = localStorage.getItem('adm_token');
  const savedEmail = localStorage.getItem('adm_email');
  if (saved && savedEmail) {
    try {
      const payload = JSON.parse(atob(saved.split('.')[1].replace(/-/g,'+').replace(/_/g,'/')));
      if (payload.exp * 1000 > Date.now()) {
        accessToken = saved;
        loginScreen.hidden = true; admApp.hidden = false;
        setAvatar(savedEmail);
        initApp();
        return;
      }
    } catch(e) {}
    localStorage.removeItem('adm_token');
    localStorage.removeItem('adm_email');
  }
})();

loginBtn.addEventListener('click', async () => {
  const email = document.getElementById('loginEmail').value.trim();
  const pw    = document.getElementById('loginPass').value;
  if (!email || !pw) { loginMsg.textContent = 'Fill in all fields'; loginMsg.className = 'adm-msg error'; return; }
  loginBtn.disabled = true; loginBtn.textContent = 'Signing in...';
  loginMsg.textContent = ''; loginMsg.className = 'adm-msg';
  try {
    const d = await sbLogin(email, pw);
    if (d.error || !d.access_token) {
      loginMsg.textContent = `Access denied: ${d.error_description || d.error || 'Invalid credentials'}`;
      loginMsg.className = 'adm-msg error';
    } else {
      accessToken = d.access_token;
      localStorage.setItem('adm_token', d.access_token);
      localStorage.setItem('adm_email', email);
      setAvatar(email);
      loginScreen.hidden = true; admApp.hidden = false;
      await initApp();
    }
  } catch(e) { loginMsg.textContent = `Error: ${e.message}`; loginMsg.className = 'adm-msg error'; }
  finally { loginBtn.disabled = false; loginBtn.textContent = 'Sign in'; }
});
document.getElementById('loginPass').addEventListener('keydown', e => { if (e.key === 'Enter') loginBtn.click(); });
document.getElementById('logoutBtn').addEventListener('click', () => {
  accessToken = null;
  localStorage.removeItem('adm_token');
  localStorage.removeItem('adm_email');
  admApp.hidden = true; loginScreen.hidden = false;
});

/* ── SIDEBAR TOGGLE ── */
document.getElementById('sidebarToggle').addEventListener('click', () => admApp.classList.toggle('sidebar-collapsed'));

/* ── PANEL SWITCHING ── */
const navItems = document.querySelectorAll('.adm-nav-item');
const PANELS = ['dashboard','pages','preview','sections','seo','media','settings','users'];

window.switchPanel = function(name) {
  navItems.forEach(n => n.classList.toggle('active', n.dataset.panel === name));
  document.querySelectorAll('.adm-sb-page').forEach(p => p.classList.remove('active'));

  PANELS.forEach(k => {
    const el = document.getElementById(k + 'Panel');
    if (!el) return;
    const isPreview = k === 'preview';
    const cls = isPreview ? 'panel-active' : 'panel-active';
    el.classList.toggle(cls, k === name);
    // preview panel uses flex, others block — handled via CSS classes already
    if (isPreview) {
      el.style.display = k === name ? 'flex' : 'none';
      el.classList.toggle('panel-active', k === name);
    }
  });

  if (name === 'seo')      fillSeo();
  if (name === 'settings') fillSettings();
  if (name === 'media')    loadMedia();
  if (name === 'users')    loadUsers();
  if (name === 'sections') loadSections();
};

navItems.forEach(item => item.addEventListener('click', () => switchPanel(item.dataset.panel)));

/* ── PAGE SELECTION (sidebar sub-items) ── */
document.querySelectorAll('.adm-sb-page').forEach(p => {
  p.addEventListener('click', () => openPreview(p.dataset.url, p.dataset.label));
});

window.openPreview = function(url, label) {
  document.querySelectorAll('.adm-sb-page').forEach(p => p.classList.toggle('active', p.dataset.url === url));
  navItems.forEach(n => n.classList.toggle('active', n.dataset.panel === 'pages'));
  // activate preview panel
  PANELS.forEach(k => {
    const el = document.getElementById(k + 'Panel');
    if (!el) return;
    if (k === 'preview') { el.style.display = 'flex'; el.classList.add('panel-active'); }
    else { el.style.display = ''; el.classList.remove('panel-active'); }
  });
  document.getElementById('previewUrl').textContent = url;
  const frame = document.getElementById('previewFrame');
  frame.src = url;
  // close float props
  document.getElementById('floatProps').classList.remove('open');
};

/* ── FLOAT PROPS ── */
document.getElementById('fpClose').addEventListener('click', () => {
  document.getElementById('floatProps').classList.remove('open');
});

let selectedPath = null, selectedType = null;

window.addEventListener('message', e => {
  if (e.data?.type !== 'adm-select') return;
  const { path, value, computedColor, computedBg, computedFontSize, isImg } = e.data;
  selectedPath = path; selectedType = isImg ? 'imagen' : 'texto';

  document.getElementById('fpTitle').textContent = isImg ? 'Imagen' : 'Texto';
  document.getElementById('fieldPath').textContent = path || '—';
  document.getElementById('fieldType').textContent = selectedType;
  document.getElementById('ctrlText').hidden = !!isImg;
  document.getElementById('ctrlImg').hidden  = !isImg;
  if (isImg) document.getElementById('propImgUrl').value = value || '';
  else       document.getElementById('propText').value   = value || '';

  const tc = normColor(computedColor || '');
  const bc = normColor(computedBg || '');
  document.getElementById('propTextColor').value    = tc;
  document.getElementById('propTextColorHex').value = tc;
  document.getElementById('propBgColor').value      = bc;
  document.getElementById('propBgColorHex').value   = bc;
  document.getElementById('propFontSize').value     = computedFontSize || '';
  document.getElementById('floatProps').classList.add('open');
  document.getElementById('saveMessage').textContent = '';
});

function normColor(c) {
  if (!c || c === 'rgba(0, 0, 0, 0)' || c === 'transparent') return '#ffffff';
  const m = c.match(/\d+/g);
  if (!m) return '#000000';
  return '#' + [m[0],m[1],m[2]].map(n => parseInt(n).toString(16).padStart(2,'0')).join('');
}

['TextColor','BgColor'].forEach(k => {
  const p = document.getElementById(`prop${k}`);
  const h = document.getElementById(`prop${k}Hex`);
  const cssProp = k === 'TextColor' ? 'color' : 'backgroundColor';
  p.addEventListener('input', () => {
    h.value = p.value;
    if (selectedPath) document.getElementById('previewFrame').contentWindow?.postMessage({ type:'adm-style', path:selectedPath, prop:cssProp, value:p.value }, '*');
  });
  h.addEventListener('change', () => {
    if (/^#[0-9a-fA-F]{6}$/.test(h.value)) {
      p.value = h.value;
      if (selectedPath) document.getElementById('previewFrame').contentWindow?.postMessage({ type:'adm-style', path:selectedPath, prop:cssProp, value:h.value }, '*');
    }
  });
});

document.getElementById('propText').addEventListener('input', () => {
  if (selectedPath) document.getElementById('previewFrame').contentWindow?.postMessage({ type:'adm-update', path:selectedPath, value:document.getElementById('propText').value }, '*');
});
document.getElementById('propFontSize').addEventListener('change', () => {
  const fs = document.getElementById('propFontSize').value;
  if (selectedPath && fs) document.getElementById('previewFrame').contentWindow?.postMessage({ type:'adm-style', path:selectedPath, prop:'fontSize', value:fs }, '*');
});

/* ── HISTORY / SAVE ── */
function applyToSite(path, val) {
  const parts = path.split('.');
  let o = site;
  for (let i = 0; i < parts.length - 1; i++) { if (!o[parts[i]]) o[parts[i]] = {}; o = o[parts[i]]; }
  o[parts[parts.length-1]] = val;
}
function getFromSite(path) { return path.split('.').reduce((o,k) => o?.[k], site); }

function pushHist(path, oldV, newV) {
  hist = hist.slice(0, histIdx + 1);
  hist.push({ path, oldV, newV, ts: new Date().toLocaleTimeString() });
  histIdx = hist.length - 1;
  renderHist();
  document.getElementById('undoBtn').disabled = false;
  document.getElementById('redoBtn').disabled = true;
}
function renderHist() {
  const ul = document.getElementById('historyList');
  ul.innerHTML = '';
  hist.slice().reverse().slice(0,8).forEach(h => {
    const li = document.createElement('li'); li.textContent = `${h.ts} · ${h.path}`; ul.appendChild(li);
  });
}

document.getElementById('undoBtn').addEventListener('click', () => {
  if (histIdx < 0) return;
  const h = hist[histIdx--];
  applyToSite(h.path, h.oldV);
  document.getElementById('undoBtn').disabled = histIdx < 0;
  document.getElementById('redoBtn').disabled = false;
  postUpdate(h.path, h.oldV);
});
document.getElementById('redoBtn').addEventListener('click', () => {
  if (histIdx >= hist.length - 1) return;
  const h = hist[++histIdx];
  applyToSite(h.path, h.newV);
  document.getElementById('undoBtn').disabled = false;
  document.getElementById('redoBtn').disabled = histIdx >= hist.length - 1;
  postUpdate(h.path, h.newV);
});

function postUpdate(path, val) {
  document.getElementById('previewFrame').contentWindow?.postMessage({ type:'adm-update', path, value:val }, '*');
}

document.getElementById('saveBtn').addEventListener('click', async () => {
  if (!selectedPath) return;
  const isImg = selectedType === 'imagen';
  const newV  = isImg ? document.getElementById('propImgUrl').value : document.getElementById('propText').value;
  pushHist(selectedPath, getFromSite(selectedPath), newV);
  applyToSite(selectedPath, newV);

  /* Apply preview immediately — before the async save */
  const fw = document.getElementById('previewFrame').contentWindow;
  postUpdate(selectedPath, newV);
  const tc = document.getElementById('propTextColor').value;
  const bc = document.getElementById('propBgColor').value;
  const fs = document.getElementById('propFontSize').value;
  if (tc) fw?.postMessage({ type:'adm-style', path:selectedPath, prop:'color', value:tc }, '*');
  if (bc) fw?.postMessage({ type:'adm-style', path:selectedPath, prop:'backgroundColor', value:bc }, '*');
  if (fs) fw?.postMessage({ type:'adm-style', path:selectedPath, prop:'fontSize', value:fs }, '*');

  const msg = document.getElementById('saveMessage');
  msg.textContent = 'Saving...'; msg.className = '';
  try {
    await saveContent(site);
    msg.textContent = 'Saved ✓';
  } catch(e) { msg.textContent = `Error: ${e.message}`; msg.className = 'error'; }
});

/* ── PUBLISH ── */
async function doPublish() {
  if (!HOOK) { alert('No hay Build Hook configurado.'); return; }
  const btn = document.getElementById('publishBtn');
  const qa  = document.getElementById('qaPublish');
  btn.disabled = true; btn.textContent = 'Publicando...';
  try {
    await fetch(HOOK, { method:'POST' });
    btn.textContent = '✓ Publicado';
    if (qa) { const os = qa.querySelector('span').textContent; qa.querySelector('span').textContent = '✓ Publicado!'; setTimeout(() => qa.querySelector('span').textContent = os, 3000); }
    setTimeout(() => { btn.textContent = '↑ Publicar sitio'; btn.disabled = false; }, 3000);
  } catch { btn.textContent = '↑ Publicar sitio'; btn.disabled = false; }
}
document.getElementById('publishBtn').addEventListener('click', doPublish);
document.getElementById('qaPublish')?.addEventListener('click', doPublish);

/* ── SEO ── */
function fillSeo() {
  document.getElementById('seoTitle').value    = site.meta?.title ?? '';
  document.getElementById('seoDesc').value     = site.meta?.description ?? '';
  document.getElementById('seoKeywords').value = site.meta?.keywords ?? '';
  document.getElementById('seoOgTitle').value  = site.meta?.ogTitle ?? '';
  document.getElementById('seoOgDesc').value   = site.meta?.ogDescription ?? '';
  document.getElementById('seoOgImage').value  = site.meta?.ogImage ?? '';
}
document.getElementById('saveSeoBtn').addEventListener('click', async () => {
  if (!site.meta) site.meta = {};
  Object.assign(site.meta, { title: document.getElementById('seoTitle').value, description: document.getElementById('seoDesc').value, keywords: document.getElementById('seoKeywords').value, ogTitle: document.getElementById('seoOgTitle').value, ogDescription: document.getElementById('seoOgDesc').value, ogImage: document.getElementById('seoOgImage').value });
  const m = document.getElementById('seoMsg'); m.textContent = 'Saving...';
  try { await saveContent(site); m.textContent = 'SEO guardado ✓'; m.className = 'adm-panel-msg'; }
  catch(e) { m.textContent = `Error: ${e.message}`; m.className = 'adm-panel-msg error'; }
});

/* ── SETTINGS ── */
function fillSettings() {
  document.getElementById('cfgFormEmail').value = site.contact?.web3forms?.email ?? '';
  document.getElementById('cfgWeb3Key').value   = site.contact?.web3forms?.key ?? '';
  document.getElementById('cfgPhone').value     = site.topContact?.phoneDisplay ?? site.topContact?.phone ?? '';
  document.getElementById('cfgWhatsapp').value  = site.topContact?.whatsappHref ?? '';
  document.getElementById('cfgEmail').value     = site.topContact?.email ?? '';
}
document.getElementById('saveSettingsBtn').addEventListener('click', async () => {
  if (!site.contact) site.contact = {};
  if (!site.contact.web3forms) site.contact.web3forms = {};
  if (!site.topContact) site.topContact = {};
  site.contact.web3forms.email  = document.getElementById('cfgFormEmail').value;
  site.contact.web3forms.key    = document.getElementById('cfgWeb3Key').value;
  site.topContact.phoneDisplay  = document.getElementById('cfgPhone').value;
  site.topContact.phone         = document.getElementById('cfgPhone').value;
  site.topContact.whatsappHref  = document.getElementById('cfgWhatsapp').value;
  site.topContact.email         = document.getElementById('cfgEmail').value;
  const m = document.getElementById('settingsMsg'); m.textContent = 'Saving...';
  try { await saveContent(site); m.textContent = 'Settings saved ✓'; m.className = 'adm-panel-msg'; }
  catch(e) { m.textContent = `Error: ${e.message}`; m.className = 'adm-panel-msg error'; }
});

/* ── SECTIONS ── */
const SECTION_LABELS = { hero:'Hero / Main banner', benefits:'Benefits', services:'Services', why:'Why choose us?', contact:'Contact form', footer:'Footer' };
function loadSections() {
  const order = site.sectionOrder ?? Object.keys(SECTION_LABELS);
  const c = document.getElementById('sectionsList'); c.innerHTML = '';
  order.forEach((key, i) => {
    const row = document.createElement('div');
    row.className = 'adm-section-row'; row.draggable = true; row.dataset.key = key;
    row.innerHTML = `<svg class="drag-handle" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="9" y1="4" x2="9" y2="20"/><line x1="15" y1="4" x2="15" y2="20"/></svg><span>${i+1}. ${SECTION_LABELS[key]??key}</span>`;
    c.appendChild(row);
  });
  initDrag(c);
}
function initDrag(c) {
  let dragged = null;
  c.querySelectorAll('.adm-section-row').forEach(row => {
    row.addEventListener('dragstart', () => { dragged = row; setTimeout(() => row.classList.add('dragging'), 0); });
    row.addEventListener('dragend', () => { row.classList.remove('dragging'); dragged = null; renum(c); });
    row.addEventListener('dragover', e => { e.preventDefault(); row.classList.add('drag-over'); if (dragged && dragged !== row) c.insertBefore(dragged, row); });
    row.addEventListener('dragleave', () => row.classList.remove('drag-over'));
    row.addEventListener('drop', e => { e.preventDefault(); row.classList.remove('drag-over'); });
  });
}
function renum(c) {
  c.querySelectorAll('.adm-section-row').forEach((r,i) => r.querySelector('span').textContent = `${i+1}. ${SECTION_LABELS[r.dataset.key]??r.dataset.key}`);
}
document.getElementById('saveSectionsBtn').addEventListener('click', async () => {
  site.sectionOrder = Array.from(document.querySelectorAll('#sectionsList .adm-section-row')).map(r => r.dataset.key);
  const m = document.getElementById('sectionsMsg'); m.textContent = 'Saving...';
  try { await saveContent(site); m.textContent = 'Orden guardado ✓'; m.className = 'adm-panel-msg'; }
  catch(e) { m.textContent = `Error: ${e.message}`; m.className = 'adm-panel-msg error'; }
});

/* ── MEDIA ── */
const BUCKET = 'media';
async function loadMedia() {
  const g = document.getElementById('mediaGrid');
  g.innerHTML = '<p style="color:var(--muted);font-size:.8rem;grid-column:1/-1">Loading...</p>';
  try {
    const r = await fetch(`${SB_URL}/storage/v1/object/list/${BUCKET}`, { method:'POST', headers:sbH(), body:JSON.stringify({ prefix:'', limit:100, offset:0, sortBy:{ column:'created_at', order:'desc' } }) });
    if (!r.ok) throw new Error(`HTTP ${r.status} — create a public "media" bucket in Supabase Storage`);
    renderMedia(await r.json());
  } catch(e) { g.innerHTML = `<p style="color:var(--red);font-size:.8rem;grid-column:1/-1">${e.message}</p>`; }
}
function renderMedia(files) {
  const g = document.getElementById('mediaGrid');
  const valid = (Array.isArray(files) ? files : []).filter(f => f.name && f.name !== '.emptyFolderPlaceholder');
  if (!valid.length) { g.innerHTML = '<p style="color:var(--muted);font-size:.8rem;grid-column:1/-1">No images uploaded yet.</p>'; return; }
  g.innerHTML = '';
  valid.forEach(f => {
    const url = `${SB_URL}/storage/v1/object/public/${BUCKET}/${f.name}`;
    const item = document.createElement('div'); item.className = 'adm-media-item';
    item.innerHTML = `<img class="adm-media-thumb" src="${url}" alt="${f.name}" loading="lazy"/><div class="adm-media-name">${f.name}</div><button class="adm-media-copy" data-url="${url}">Copiar URL</button>`;
    g.appendChild(item);
  });
  g.querySelectorAll('.adm-media-copy').forEach(btn => {
    btn.addEventListener('click', () => { navigator.clipboard.writeText(btn.dataset.url).then(() => { const o = btn.textContent; btn.textContent='✓ Copiado'; setTimeout(()=>btn.textContent=o,1800); }); });
  });
}
const uploadZone = document.getElementById('uploadZone');
const mediaInput = document.getElementById('mediaFileInput');
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-active'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-active'));
uploadZone.addEventListener('drop', async e => { e.preventDefault(); uploadZone.classList.remove('drag-active'); await uploadFiles(e.dataTransfer.files); });
mediaInput.addEventListener('change', async () => { await uploadFiles(mediaInput.files); mediaInput.value=''; });
async function uploadFiles(files) {
  if (!files.length) return;
  const m = document.getElementById('uploadMsg'); m.textContent = `Subiendo ${files.length} archivo(s)...`; m.className='adm-panel-msg';
  let ok=0, fail=0;
  for (const file of files) {
    if (file.size > 5*1024*1024) { fail++; continue; }
    const name = `${Date.now()}-${file.name.replace(/[^a-zA-Z0-9._-]/g,'_')}`;
    try { const r = await fetch(`${SB_URL}/storage/v1/object/${BUCKET}/${name}`, { method:'POST', headers:{ apikey:SB_KEY, Authorization:`Bearer ${accessToken}`, 'Content-Type':file.type, 'x-upsert':'false' }, body:file }); r.ok ? ok++ : fail++; }
    catch { fail++; }
  }
  m.textContent = `${ok} subido(s)${fail?`, ${fail} con error`:''}.`; m.className = fail ? 'adm-panel-msg error' : 'adm-panel-msg';
  loadMedia();
}

/* ── USERS ── */
function decodeJWT(token) { try { return JSON.parse(atob(token.split('.')[1].replace(/-/g,'+').replace(/_/g,'/'))); } catch { return {}; } }
function loadUsers() {
  const payload = decodeJWT(accessToken || '');
  const email   = payload.email || '—';
  const uid     = payload.sub   || '—';
  const initials = email.substring(0,2).toUpperCase();
  const exp = payload.exp ? new Date(payload.exp * 1000).toLocaleString('es') : '—';
  document.getElementById('currentUserInfo').innerHTML = `
    <table class="adm-user-table">
      <thead><tr><th></th><th>User</th><th>ID</th><th>Session expires</th><th>Status</th></tr></thead>
      <tbody>
        <tr>
          <td><div class="adm-user-avatar">${initials}</div></td>
          <td><strong>${email}</strong></td>
          <td style="font-size:.72rem;color:var(--muted);font-family:monospace">${uid.substring(0,8)}...</td>
          <td style="font-size:.75rem;color:var(--muted)">${exp}</td>
          <td><span class="adm-user-badge active">Active</span></td>
        </tr>
      </tbody>
    </table>`;
  const ref = SB_URL.match(/https:\/\/([^.]+)\.supabase\.co/)?.[1] ?? '';
  document.getElementById('supabaseAuthLink').href = ref ? `https://supabase.com/dashboard/project/${ref}/auth/users` : 'https://supabase.com/dashboard';
}

/* ── INIT ── */
async function initApp() {
  document.getElementById('statusBadge').textContent = 'Loading...';
  try {
    site = await loadContent();
    document.getElementById('statusBadge').textContent = 'Connected';
    // inject bridge on every iframe load
    document.getElementById('previewFrame').addEventListener('load', injectBridge);
  } catch(e) { document.getElementById('statusBadge').textContent = 'Error loading content'; }
}

/* ── BRIDGE ── */
function injectBridge() {
  try {
    const win = document.getElementById('previewFrame').contentWindow;
    if (win.__admBridgeActive) return;
    const s = win.document.createElement('script');
    s.textContent = `(${bridgeFn.toString()})()`;
    win.document.head.appendChild(s);
  } catch(e) { console.warn('Bridge inject failed:', e); }
}

function bridgeFn() {
  if (window.__admBridgeActive) return;
  window.__admBridgeActive = true;
  let hovered = null, selected = null;
  const HL = '2px dashed #c8913a', SEL = '2px solid #2271b1';

  document.addEventListener('mouseover', e => {
    const t = e.target.closest('[data-content-path]');
    if (hovered && hovered !== selected) hovered.style.outline = '';
    hovered = t;
    if (t && t !== selected) { t.style.outline = HL; t.style.cursor = 'pointer'; }
  });
  document.addEventListener('mouseout', e => {
    const t = e.target.closest('[data-content-path]');
    if (t && t !== selected) t.style.outline = '';
  });
  document.addEventListener('click', e => {
    const t = e.target.closest('[data-content-path]');
    if (!t) { if (selected) { selected.style.outline = ''; selected = null; } return; }
    e.preventDefault(); e.stopPropagation();
    if (selected && selected !== t) selected.style.outline = '';
    selected = t; t.style.outline = SEL;
    const path = t.dataset.contentPath;
    const img  = t.tagName === 'IMG' ? t : t.querySelector('img');
    const cs   = window.getComputedStyle(t);
    window.parent.postMessage({ type:'adm-select', path, value: img ? (img.getAttribute('src')||img.src) : t.innerText, isImg:!!img, computedColor:cs.color, computedBg:cs.backgroundColor, computedFontSize:cs.fontSize }, '*');
  }, true);
  window.addEventListener('message', e => {
    if (e.data?.type === 'adm-update') {
      document.querySelectorAll(`[data-content-path="${e.data.path}"]`).forEach(el => {
        const img = el.tagName==='IMG' ? el : el.querySelector('img');
        if (img) img.src = e.data.value; else el.innerText = e.data.value;
      });
    }
    if (e.data?.type === 'adm-style') {
      document.querySelectorAll(`[data-content-path="${e.data.path}"]`).forEach(el => { el.style[e.data.prop] = e.data.value; });
    }
  });
}

/* init preview panel display */
document.getElementById('previewPanel').style.display = 'none';
</script>
