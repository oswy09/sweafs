---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.vue';
import SiteHeader from '../components/SiteHeader.vue';
import { site } from '../data/site';

const whyIcons = ['bi-shield-check', 'bi-recycle', 'bi-lightning-charge'];
const [featuredService, ...simpleServices] = site.services;
const showGallery = featuredService?.showGallery === true;
// Display order: Taktvätt(0), Sten(3), Fasadtvätt(1), Klottersanering(2)
const s = site.services;
const displayServices = [
  { service: s[0], idx: 0 },
  { service: s[3], idx: 3 },
  { service: s[1], idx: 1 },
  { service: s[2], idx: 2 },
].filter(d => d.service);

const optimizeCloudinaryImage = (url: string, transforms = 'f_auto,q_auto:eco,w_1920,dpr_auto') => {
  const uploadSegment = '/upload/';
  if (!url.includes('res.cloudinary.com') || !url.includes(uploadSegment)) {
    return url;
  }
  return url.replace(uploadSegment, `${uploadSegment}${transforms}/`);
};

const heroImageOptimized = optimizeCloudinaryImage(site.hero.image);
---

<BaseLayout title={site.meta.title} description={site.meta.description}>
  <link slot="head" rel="preload" as="image" href={heroImageOptimized} fetchpriority="high" />
  <SiteHeader client:idle logo={site.logo} links={site.navigation} topContact={site.topContact} />

  <main>
    <section id="hero" class="hero-shell">
      <div class="hero-bg" aria-hidden="true">
        <img
          src={heroImageOptimized}
          alt=""
          loading="eager"
          fetchpriority="high"
          decoding="async"
          data-content-src-path="hero.image"
        />
      </div>
      <div class="hero-content">
        <p class="hero-eyebrow" data-content-path="hero.eyebrow">{site.hero.eyebrow}</p>
        <h1 class="hero-title animate-title" data-content-path="hero.title">{site.hero.title}</h1>
        <p class="hero-sub animate-title" data-content-path="hero.subtitle">{site.hero.subtitle}</p>
        <div class="hero-btns">
          <a href="#contact-form" class="btn-primary animate-btn"><i class="bi bi-envelope-fill" aria-hidden="true"></i> <span data-content-path="hero.primaryCta">{site.hero.primaryCta}</span></a>
          <a href="#services" class="btn-outline animate-btn" data-content-path="hero.secondaryCta">{site.hero.secondaryCta}</a>
        </div>
      </div>
      <a href="#services" class="hero-scroll">↓</a>
    </section>

    <div class="benefits-band">
      <div class="benefits-inner">
        {site.benefits.map((benefit, index) => (
          <article class="benefit-card reveal">
            <p class="benefit-card-title" data-content-path={`benefits.${index}.title`}>{benefit.title}</p>
            <p data-content-path={`benefits.${index}.body`}>{benefit.body}</p>
          </article>
        ))}
      </div>
    </div>

    <section id="services">
      <div class="section-inner">
        <p class="section-eyebrow" data-content-path="servicesSection.eyebrow">{site.servicesSection.eyebrow}</p>
        <h2 class="section-title animate-title" data-content-path="servicesSection.title">{site.servicesSection.title}</h2>
        <p class="section-lead" data-content-path="servicesSection.lead">{site.servicesSection.lead}</p>

        <div class="service-simple-grid">
          {displayServices.map(({ service, idx }) => (
            <article class="service-simple-item reveal">
              <div class="service-text">
                <h3 class="animate-title" data-content-path={`services.${idx}.title`}>{service.title}</h3>
                <p data-content-path={`services.${idx}.body`}>{service.body}</p>
                <a href="#contact" class="btn-navy animate-btn" data-content-path={`services.${idx}.cta`}>{service.cta}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="why">
      <div class="section-inner">
        <p class="section-eyebrow" data-content-path="why.eyebrow">{site.why.eyebrow}</p>
        <h2 class="section-title animate-title" data-content-path="why.title">{site.why.title}</h2>
        <p class="section-lead" data-content-path="why.lead">{site.why.lead}</p>
        <div class="why-grid">
          {site.why.items.map((item, index) => (
            <div class="why-card reveal">
              <div class="why-icon"><i class:list={["bi", whyIcons[index] || 'bi-circle']} aria-hidden="true"></i></div>
              <h3 data-content-path={`why.items.${index}.title`}>{item.title}</h3>
              <p data-content-path={`why.items.${index}.body`}>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="contact">
      <div class="section-inner">
        <p class="section-eyebrow" data-content-path="contact.eyebrow">{site.contact.eyebrow}</p>
        <h2 class="section-title animate-title" data-content-path="contact.title">{site.contact.title}</h2>
        <p class="section-lead" data-content-path="contact.lead">{site.contact.lead}</p>
        <div class="contact-quick-actions">
          <a class="contact-pill" href={site.footer.phoneHref} data-content-href-path="footer.phoneHref"><i class="bi bi-telephone-fill" aria-hidden="true"></i> <span data-content-path="footer.phoneLabel">{site.footer.phoneLabel}</span></a>
          <a class="contact-pill" href={site.footer.emailHref} data-content-href-path="footer.emailHref"><i class="bi bi-envelope-fill" aria-hidden="true"></i> <span data-content-path="footer.emailLabel">{site.footer.emailLabel}</span></a>
        </div>
        <div id="contact-form" class="contact-wrapper">
          <ContactForm
            client:visible
            fields={site.contact.fields}
            submitLabel={site.contact.submitLabel}
            successMessage={site.contact.successMessage}
            web3forms={site.contact.web3forms}
          />
        </div>
      </div>
    </section>

  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-block footer-brand-block">
        <p class="footer-brand"><span data-content-path="footer.brand.label">{site.footer.brand.label}</span> <span data-content-path="footer.brand.accent">{site.footer.brand.accent}</span></p>
        <p class="footer-copy">&copy; {new Date().getFullYear()} <span data-content-path="footer.brand.label">{site.footer.brand.label}</span> <span data-content-path="footer.brand.accent">{site.footer.brand.accent}</span>. <span data-content-path="footer.copy">{site.footer.copy}</span></p>
      </div>
      <div class="footer-block footer-links">
        <a href="#services" data-content-path="navigation.0.label" data-content-href-path="navigation.0.href">Tjänster</a>
        <a href="#why" data-content-path="navigation.1.label" data-content-href-path="navigation.1.href">Om oss</a>
        <a href="#contact" data-content-path="navigation.3.label" data-content-href-path="navigation.3.href">Begär offert</a>
      </div>
      <div class="footer-block footer-contact">
        <a href={site.footer.phoneHref} data-content-href-path="footer.phoneHref"><i class="bi bi-telephone-fill" aria-hidden="true"></i> <span data-content-path="footer.phoneLabel">{site.footer.phoneLabel}</span></a>
        <a href={site.footer.emailHref} data-content-href-path="footer.emailHref"><i class="bi bi-envelope-fill" aria-hidden="true"></i> <span data-content-path="footer.emailLabel">{site.footer.emailLabel}</span></a>
      </div>
    </div>
  </footer>

  <a class="whatsapp-float" href={site.footer.whatsappHref} target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp" data-content-href-path="footer.whatsappHref">
    <i class="bi bi-whatsapp" aria-hidden="true"></i>
  </a>

  <script>
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const startAnimations = async () => {
      if (prefersReducedMotion) return;

      const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger'),
      ]);

      gsap.registerPlugin(ScrollTrigger);

      gsap.from('nav', {
        y: -36,
        opacity: 0,
        duration: 0.9,
        ease: 'power2.out',
      });

      gsap.set('.animate-title, .animate-btn, .animate-img, .reveal', { willChange: 'transform, opacity' });

      const mm = gsap.matchMedia();

      const buildTimeline = (config) => {
        const section = document.querySelector(config.selector);
        if (!section) return;

        const titles = section.querySelectorAll('.animate-title');
        const buttons = section.querySelectorAll('.animate-btn, .btn-submit');
        const images = section.querySelectorAll('.animate-img');

        if (!titles.length && !buttons.length && !images.length) return;

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            start: config.start,
            end: config.end,
            scrub: true,
            markers: false,
          },
        });

        if (titles.length) {
          tl.from(titles, {
            y: 50,
            opacity: 0,
            scale: 0.9,
            ease: 'power2.out',
            stagger: config.stagger,
            duration: config.titleDuration,
          });
        }

        if (buttons.length) {
          tl.from(
            buttons,
            {
              y: 50,
              opacity: 0,
              scale: 0.9,
              ease: 'power2.out',
              stagger: config.stagger,
              duration: config.buttonDuration,
            },
            '-=0.45',
          );
        }

        if (images.length) {
          tl.from(
            images,
            {
              y: 50,
              opacity: 0,
              scale: 0.9,
              ease: 'power2.out',
              stagger: config.stagger,
              duration: config.imageDuration,
            },
            '-=0.35',
          );
        }
      };

      mm.add('(min-width: 769px)', () => {
        [
          {
            selector: '#hero',
            start: 'top 88%',
            end: 'bottom 58%',
            stagger: 0.15,
            titleDuration: 1.3,
            buttonDuration: 1,
            imageDuration: 1.1,
          },
          {
            selector: '#services',
            start: 'top 115%',
            end: 'bottom 78%',
            stagger: 0.13,
            titleDuration: 1.1,
            buttonDuration: 0.95,
            imageDuration: 1.05,
          },
          {
            selector: '#why',
            start: 'top 82%',
            end: 'bottom 62%',
            stagger: 0.12,
            titleDuration: 1,
            buttonDuration: 0.9,
            imageDuration: 0.95,
          },
          {
            selector: '#contact',
            start: 'top 82%',
            end: 'bottom 62%',
            stagger: 0.12,
            titleDuration: 1,
            buttonDuration: 0.95,
            imageDuration: 0.95,
          },
        ].forEach(buildTimeline);

        gsap.utils.toArray('.reveal').forEach((element) => {
          gsap.fromTo(
            element,
            { y: 50, opacity: 0, scale: 0.9 },
            {
              y: 0,
              opacity: 1,
              scale: 1,
              ease: 'power2.out',
              duration: 1,
              scrollTrigger: {
                trigger: element,
                start: 'top 86%',
                end: 'bottom 66%',
                scrub: true,
                markers: false,
              },
            },
          );
        });
      });

      mm.add('(max-width: 768px)', () => {
        [
          {
            selector: '#hero',
            start: 'top 92%',
            end: 'bottom 72%',
            stagger: 0.08,
            titleDuration: 0.85,
            buttonDuration: 0.8,
            imageDuration: 0.85,
          },
          {
            selector: '#services',
            start: 'top 118%',
            end: 'bottom 84%',
            stagger: 0.08,
            titleDuration: 0.8,
            buttonDuration: 0.75,
            imageDuration: 0.8,
          },
          {
            selector: '#why',
            start: 'top 90%',
            end: 'bottom 70%',
            stagger: 0.08,
            titleDuration: 0.78,
            buttonDuration: 0.75,
            imageDuration: 0.78,
          },
          {
            selector: '#contact',
            start: 'top 90%',
            end: 'bottom 70%',
            stagger: 0.08,
            titleDuration: 0.78,
            buttonDuration: 0.75,
            imageDuration: 0.78,
          },
        ].forEach(buildTimeline);

        gsap.utils.toArray('.reveal').forEach((element) => {
          gsap.fromTo(
            element,
            { y: 50, opacity: 0, scale: 0.9 },
            {
              y: 0,
              opacity: 1,
              scale: 1,
              ease: 'power2.out',
              duration: 0.75,
              scrollTrigger: {
                trigger: element,
                start: 'top 92%',
                end: 'bottom 72%',
                scrub: true,
                markers: false,
              },
            },
          );
        });
      });

      gsap.to('.hero-bg', {
        yPercent: 8,
        ease: 'none',
        scrollTrigger: {
          trigger: '#hero',
          start: 'top top',
          end: 'bottom top',
          scrub: true,
          markers: false,
        },
      });

      gsap.to('.whatsapp-float', {
        y: -10,
        repeat: -1,
        yoyo: true,
        ease: 'power2.out',
        duration: 1.4,
      });
    };

    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(startAnimations, { timeout: 1500 });
    } else {
      window.setTimeout(startAnimations, 300);
    }
  </script>
</BaseLayout>