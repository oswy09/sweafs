---
import { site, themeVars } from '../data/site';
import '../styles/global.css';

const {
  title = site.meta.title,
  description = site.meta.description,
  lang = 'sv',
} = Astro.props;

const themeCss = Object.entries(themeVars)
  .map(([name, value]) => `${name}:${value};`)
  .join('');

const serializedSite = JSON.stringify(site).replace(/</g, '\\u003c');
const serializedRuntimeConfig = JSON.stringify({
  supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL || '',
  supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '',
  contentKey: import.meta.env.PUBLIC_SITE_CONTENT_KEY || 'main',
}).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang={lang} style={themeCss}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="dns-prefetch" href="//res.cloudinary.com" />
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />
    <link rel="dns-prefetch" href="//cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <slot name="head" />
  </head>
  <body>
    <script id="site-content-fallback" type="application/json" set:html={serializedSite}></script>
    <script id="runtime-config" type="application/json" set:html={serializedRuntimeConfig}></script>
    <slot />

    <script>
      const fallbackEl = document.getElementById('site-content-fallback');
      const runtimeConfigEl = document.getElementById('runtime-config');
      const fallback = fallbackEl ? JSON.parse(fallbackEl.textContent || '{}') : {};
      const runtimeConfig = runtimeConfigEl ? JSON.parse(runtimeConfigEl.textContent || '{}') : {};

      const getByPath = (source, path) => path.split('.').reduce((acc, segment) => {
        if (acc == null) return undefined;
        return acc[segment];
      }, source);

      const applyContent = (content) => {
        document.querySelectorAll('[data-content-path]').forEach((element) => {
          const path = element.getAttribute('data-content-path');
          if (!path) return;
          const value = getByPath(content, path);
          if (value == null) return;
          element.textContent = String(value);
        });

        document.querySelectorAll('[data-content-src-path]').forEach((element) => {
          const path = element.getAttribute('data-content-src-path');
          if (!path) return;
          const value = getByPath(content, path);
          if (value == null || !(element instanceof HTMLImageElement)) return;
          element.src = String(value);
        });

        document.querySelectorAll('[data-content-alt-path]').forEach((element) => {
          const path = element.getAttribute('data-content-alt-path');
          if (!path) return;
          const value = getByPath(content, path);
          if (value == null || !(element instanceof HTMLImageElement)) return;
          element.alt = String(value);
        });

        document.querySelectorAll('[data-content-href-path]').forEach((element) => {
          const path = element.getAttribute('data-content-href-path');
          if (!path) return;
          const value = getByPath(content, path);
          if (value == null || !(element instanceof HTMLAnchorElement)) return;
          element.href = String(value);
        });

        document.querySelectorAll('[data-content-placeholder-path]').forEach((element) => {
          const path = element.getAttribute('data-content-placeholder-path');
          if (!path) return;
          const value = getByPath(content, path);
          if (value == null || (!(element instanceof HTMLInputElement) && !(element instanceof HTMLTextAreaElement))) return;
          element.placeholder = String(value);
        });

        if (content?.meta?.title) {
          document.title = String(content.meta.title);
        }

        const metaDescription = document.querySelector('meta[name="description"]');
        if (metaDescription && content?.meta?.description) {
          metaDescription.setAttribute('content', String(content.meta.description));
        }
      };

      const loadRemote = async () => {
        applyContent(fallback);

        const supabaseUrl = runtimeConfig.supabaseUrl || '';
        const supabaseAnonKey = runtimeConfig.supabaseAnonKey || '';
        if (!supabaseUrl || !supabaseAnonKey) return;

        const contentKey = runtimeConfig.contentKey || 'main';
        const response = await fetch(
          `${supabaseUrl}/rest/v1/site_content?key=eq.${encodeURIComponent(contentKey)}&select=content&limit=1`,
          {
            headers: {
              apikey: supabaseAnonKey,
            },
          },
        );

        if (!response.ok) return;

        const rows = await response.json();
        const row = Array.isArray(rows) ? rows[0] : null;

        if (row?.content && typeof row.content === 'object') {
          applyContent(row.content);
        }
      };

      loadRemote().catch(() => {
        applyContent(fallback);
      });
    </script>
  </body>
</html>